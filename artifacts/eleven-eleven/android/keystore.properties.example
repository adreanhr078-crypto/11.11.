# Android Keystore Configuration Example
# Rename this file to keystore.properties and fill in your details

# Path to your keystore file (relative to android/app directory)
storeFile=../../your-keystore.jks

# Keystore password
storePassword=yourkeystorepassword

# Key alias
keyAlias=yourkeyalias

# Key password
keyPassword=yourkeypassword

# To generate a new keystore, run:
# keytool -genkey -v -keystore your-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias yourkeyalias